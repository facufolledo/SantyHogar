# Supabase (solo en servidor / backend; nunca en frontend público)
# URL: Project Settings → API → Project URL
SUPABASE_URL=https://your-project.supabase.co
# Clave: Secret key (sb_secret_...) o legacy service_role JWT — con permisos de servidor.
# El anon key no alcanza si RLS bloquea tablas; para este API usá la secret/service.
SUPABASE_KEY=

# MercadoPago Configuration
MERCADOPAGO_ACCESS_TOKEN=your-mercadopago-access-token
MERCADOPAGO_WEBHOOK_SECRET=your-webhook-secret

# Frontend Configuration
FRONTEND_URL=http://localhost:5173

# Application Configuration
API_HOST=0.0.0.0
API_PORT=8000
