# Supabase (solo en servidor / backend; nunca en frontend público)
# URL: Project Settings → API → Project URL
SUPABASE_URL=https://your-project.supabase.co
# Clave: JWT service_role (cadena larga que empieza con eyJ...) — Project Settings → API → service_role (Reveal).
# NO uses sb_secret_ aquí: supabase-py solo acepta formato JWT. El service_role evita bloqueos de RLS en el servidor.
SUPABASE_KEY=

# MercadoPago Configuration
MERCADOPAGO_ACCESS_TOKEN=your-mercadopago-access-token
MERCADOPAGO_WEBHOOK_SECRET=your-webhook-secret

# Frontend Configuration
FRONTEND_URL=http://localhost:5173

# Si true, en errores de base la API devuelve el mensaje real (Supabase/RLS, tabla, etc.)
DEBUG=true

# Application Configuration
API_HOST=0.0.0.0
API_PORT=8000
# URL pública del API (webhook Mercado Pago: {PUBLIC_API_URL}/webhook)
PUBLIC_API_URL=http://localhost:8000
