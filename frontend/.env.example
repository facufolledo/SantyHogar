# URL base del backend FastAPI (sin barra final). Elegí UNA.
# Opción A — directo a uvicorn (reiniciá Vite tras cambiar):
VITE_API_URL=http://localhost:8000
# Opción B — desarrollo con proxy en vite.config.ts (mismo origen que Vite → /api → :8000):
# VITE_API_URL=/api

# Solo al publicar con Mercado Pago: poner true (requiere token MP en el backend)
# Sin esto o en false: checkout local (pedido en el navegador, sin cobro online)
VITE_ENABLE_MP_CHECKOUT=false
