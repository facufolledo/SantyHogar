# Obligatorio para el catálogo: URL base del backend FastAPI (sin barra final)
VITE_API_URL=http://localhost:8000

# Solo al publicar con Mercado Pago: poner true (requiere token MP en el backend)
# Sin esto o en false: checkout local (pedido en el navegador, sin cobro online)
VITE_ENABLE_MP_CHECKOUT=false
