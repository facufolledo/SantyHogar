{
  "name": "marmoleria-santa-rita",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && echo 'Build completado. Sube la carpeta dist a tu hosting.'",
    "analyze": "npm run build && npx vite-bundle-analyzer dist",
    "lighthouse": "npx lighthouse https://marmoleriasantarita.com --output=html --output-path=./lighthouse-report.html",
    "seo-check": "npx lighthouse https://marmoleriasantarita.com --only-categories=seo --output=json --output-path=./seo-report.json"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "exceljs": "^4.4.0",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.263.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^6.8.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vite-bundle-analyzer": "^0.7.0"
  },
  "keywords": [
    "marmolería",
    "granitos",
    "mármoles",
    "La Rioja",
    "Argentina",
    "cocinas",
    "baños",
    "mesadas",
    "piedras naturales",
    "diseño de interiores"
  ],
  "author": "Marmolería Santa Rita",
  "license": "MIT",
  "description": "Sitio web oficial de Marmolería Santa Rita - Especialistas en granitos y mármoles premium en La Rioja, Argentina"
}
